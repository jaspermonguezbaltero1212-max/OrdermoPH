<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ordermo"
        android:textColor="#32CD32"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Enter OTP"
            android:textColor="@android:color/black"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOtpDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="We sent a 6-digit code to"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvOtpPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="+63 XXX XXX XXXX"
            android:textColor="#32CD32"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/etOtp1"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_border_green_rounded"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="24sp"
                android:textColor="@android:color/black" />

            <EditText
                android:id="@+id/etOtp2"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_border_green_rounded"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="24sp"
                android:textColor="@android:color/black" />

            <EditText
                android:id="@+id/etOtp3"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_border_green_rounded"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="24sp"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="-"
                android:textSize="24sp"
                android:textColor="@android:color/darker_gray" />

            <EditText
                android:id="@+id/etOtp4"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_border_green_rounded"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="24sp"
                android:textColor="@android:color/black" />

            <EditText
                android:id="@+id/etOtp5"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_border_green_rounded"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="24sp"
                android:textColor="@android:color/black" />

            <EditText
                android:id="@+id/etOtp6"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_border_green_rounded"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textSize="24sp"
                android:textColor="@android:color/black" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSubmitOtp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_green_rounded"
            android:text="Verify OTP"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvResendOtp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Resend Code"
            android:textColor="#32CD32"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
